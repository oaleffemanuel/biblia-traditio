# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Importer build artifacts & generated content DB (large / regenerable)
tool/importer/.dart_tool/
tool/importer/data/*.sqlite
tool/importer/data/*.sqlite-*
tool/importer/data/normalized/
tool/importer/data/reports/

# Bundled content DB is a build artifact (large; may contain non-PD dev text).
# Regenerate with tool/build_content_db.sh — never commit it.

# Content packages are build artifacts (large; may contain dev/copyrighted text).
# Regenerate with tool/build_content_db.sh — never commit them.
assets/packages/*.sqlite.gz
assets/packages/manifest.json
tool/importer/data/*.xml
